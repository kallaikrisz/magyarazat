<Window x:Class="ujablak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ujablak.ViewModels"
        xmlns:views="clr-namespace:ujablak.Views"
        Title="MVVM Gyakorló" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <!-- ViewModel → View kapcsolat -->
    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:ListViewModel}">
            <views:ListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:InsertViewModel}">
            <views:InsertView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DeleteViewModel}">
            <views:DeleteView />
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- Felső menü -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2C3E50">

            <Button Content="Lista"
                    Command="{Binding ShowListCommand}"
                    Margin="5" Width="100"/>

            <Button Content="Új"
                    Command="{Binding ShowInsertCommand}"
                    Margin="5" Width="100"/>

            <Button Content="Törlés"
                    Command="{Binding ShowDeleteCommand}"
                    Margin="5" Width="100"/>

        </StackPanel>

        <!-- Dinamikus tartalom -->
        <ContentControl Content="{Binding CurrentView}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"/>

    </DockPanel>
</Window>